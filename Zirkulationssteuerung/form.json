{
    "elements": [

        {
            "type": "Label",
            "caption": "Schaltaktor Zirkulationspumpe"
        },
        {
            "type": "SelectVariable",
            "name": "SwitchID",
            "caption": "Zirkulationspumpe"
        },

        {
            "type": "Label",
            "caption": "Bewegungsmelder"
        },
        {
            "type": "SelectVariable",
            "name": "MotionIDBath",
            "caption": "Bewegungsmelder Bad"
        },
        {
            "type": "SelectVariable",
            "name": "MotionIDKitchen",
            "caption": "Bewegungsmelder Küche"
        },

        {
            "type": "Label",
            "caption": "Grundeinstellungen"
        },
        {
            "type": "NumberSpinner",
            "name": "Runtime",
            "caption": "Standard Laufzeit (Sekunden)"
        },
        {
            "type": "NumberSpinner",
            "name": "LockTime",
            "caption": "Sperrzeit (Sekunden)"
        },

        {
            "type": "Label",
            "caption": "Küche Erkennung"
        },
        {
            "type": "NumberSpinner",
            "name": "TriggerCount",
            "caption": "Bewegungen bis Start"
        },
        {
            "type": "NumberSpinner",
            "name": "TriggerWindow",
            "caption": "Zeitfenster (Sekunden)"
        },

        {
            "type": "Label",
            "caption": "Zeitabhängige Laufzeiten (optional)"
        },
        {
            "type": "CheckBox",
            "name": "UseTimeControl",
            "caption": "Zeitsteuerung aktivieren"
        },
        {
            "type": "NumberSpinner",
            "name": "TimeStart1",
            "caption": "Fenster 1 Start (Stunde)"
        },
        {
            "type": "NumberSpinner",
            "name": "TimeEnd1",
            "caption": "Fenster 1 Ende (Stunde)"
        },
        {
            "type": "NumberSpinner",
            "name": "Runtime1",
            "caption": "Laufzeit Fenster 1"
        },
        {
            "type": "NumberSpinner",
            "name": "TimeStart2",
            "caption": "Fenster 2 Start (Stunde)"
        },
        {
            "type": "NumberSpinner",
            "name": "TimeEnd2",
            "caption": "Fenster 2 Ende (Stunde)"
        },
        {
            "type": "NumberSpinner",
            "name": "Runtime2",
            "caption": "Laufzeit Fenster 2"
        },

        {
            "type": "Label",
            "caption": "Warmwasser-Optimierung"
        },
        {
            "type": "NumberSpinner",
            "name": "WarmWindow",
            "caption": "Zeitraum 'noch warm' (Sekunden)"
        },
        {
            "type": "NumberSpinner",
            "name": "WarmReduction",
            "caption": "Laufzeit Reduktion (%)"
        },

        {
            "type": "Label",
            "caption": "Verbrauchsberechnung"
        },
        {
            "type": "Label",
            "caption": "Hier kann die Leistungsaufnahme der Zirkulationspumpe eingestellt werden, um den Stromverbrauch zu berechnen."
        },
        {
            "type": "NumberSpinner",
            "name": "PumpPower",
            "caption": "Leistung (Watt)"
        },

        {
            "type": "Label",
            "caption": "Stromkosten"
        },
        {
            "type": "Label",
            "caption": "Hier kann der aktuelle Strompreis eingetragen werden, um die Kosten und Einsparungen zu berechnen."
        },
        {
            "type": "NumberSpinner",
            "name": "EnergyPrice",
            "caption": "Strompreis (€/kWh)",
            "digits": 3
        },

        {
            "type": "ExpansionPanel",
            "caption": "Statistik zurücksetzen",
            "items": [
                {
                    "type": "Label",
                    "caption": "⚠ Aktionen müssen erst aktiviert und dann bestätigt werden (10 Sekunden Zeitfenster)!"
                },
        
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "Tageswerte aktivieren",
                            "onClick": "ZPS_ArmReset($id, 'daily');"
                        },
                        {
                            "type": "Label",
                            "caption": "@ZPS_GetResetStatus($id)"
                        },
                        {
                            "type": "Button",
                            "caption": "JETZT zurücksetzen",
                            "onClick": "ZPS_ResetDaily($id);"
                        },
                        {
                        
                    ]
                },
        
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "Gesamtwerte aktivieren",
                            "onClick": "ZPS_ArmReset($id, 'total');"
                        },
                        {
                            "type": "Label",
                            "caption": "@ZPS_GetResetStatus($id)"
                        },
                        {
                            "type": "Button",
                            "caption": "JETZT zurücksetzen",
                            "onClick": "ZPS_ResetTotal($id);"
                        }
                    ]
                },
        
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "caption": "ALLES aktivieren",
                            "onClick": "ZPS_ArmReset($id, 'all');"
                        },
                        {
                            "type": "Label",
                            "caption": "@ZPS_GetResetStatus($id)"
                        },
                        {
                            "type": "Button",
                            "caption": "JETZT ALLES löschen",
                            "onClick": "ZPS_ResetAll($id);"
                        }
                    ]
                }
            ]
        }
    ]
}
